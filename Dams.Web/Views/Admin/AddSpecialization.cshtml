@using Dams.Web.ViewModels.Admin
@model AddSpecializationViewModel

@{
    ViewData["Title"] = "Add Specialization";
}

<div class="auth-panel mx-auto">

    <div class="page-header">

        <h1 class="h3 mb-1">
            Add Specialization
        </h1>

        <p class="text-muted">
            Create a new medical specialization.
        </p>

    </div>

    <div class="form-shell">

        <form asp-action="AddSpecialization" method="post">

            <div asp-validation-summary="ModelOnly"
                 class="text-danger mb-3">
            </div>

            <div class="mb-4">

                <label asp-for="Name" class="form-label"></label>

                <input asp-for="Name"
                       class="form-control" />

                <span asp-validation-for="Name"
                      class="text-danger"></span>

            </div>

            <button class="btn btn-primary">
                Save
            </button>

            <a asp-action="ManageSpecializations"
               class="btn btn-secondary">
                Cancel
            </a>

        </form>

    </div>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}