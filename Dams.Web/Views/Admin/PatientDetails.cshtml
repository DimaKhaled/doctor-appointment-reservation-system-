@model Dams.Web.ViewModels.Admin.PatientDetailsViewModel

@{
    ViewData["Title"] = "Patient Details";
}

<div class="page-header mb-4">

    <h1 class="display-6 fw-bold">
        Patient Details
    </h1>

    <p class="text-muted">
        View complete patient information.
    </p>

</div>

<div class="row">

    <div class="col-lg-4">

        <div class="card shadow-sm border-0">

            <div class="card-body text-center">

                @if (!string.IsNullOrWhiteSpace(Model.ProfilePicturePath))
                {
                    <img src="@Model.ProfilePicturePath"
                         class="rounded-circle mb-3"
                         style="width:170px;height:170px;object-fit:cover;" />
                }
                else
                {
                    <img src="~/images/default-patient.jpg"
                         class="rounded-circle mb-3"
                         style="width:170px;height:170px;object-fit:cover;" />
                }

                <h3>@Model.FullName</h3>

                <p class="text-muted">
                    Patient
                </p>

            </div>

        </div>

    </div>

    <div class="col-lg-8">

        <div class="card shadow-sm border-0">

            <div class="card-header">

                <h4 class="mb-0">

                    Patient Information

                </h4>

            </div>

            <div class="card-body">

                <table class="table table-borderless">

                    <tr>
                        <th width="220">Email</th>
                        <td>@Model.Email</td>
                    </tr>

                    <tr>
                        <th>Phone Number</th>
                        <td>@Model.PhoneNumber</td>
                    </tr>

                    <tr>
                        <th>Gender</th>
                        <td>@Model.Gender</td>
                    </tr>

                    <tr>
                        <th>Date of Birth</th>
                        <td>@Model.DateOfBirth.ToString("dd MMM yyyy")</td>
                    </tr>

                    <tr>
                        <th>Blood Type</th>
                        <td>@Model.BloodType</td>
                    </tr>

                    <tr>
                        <th>Allergies</th>
                        <td>@Model.Allergies</td>
                    </tr>

                    <tr>
                        <th>Chronic Diseases</th>
                        <td>@Model.ChronicDiseases</td>
                    </tr>

                </table>

            </div>

        </div>

    </div>

</div>

<div class="mt-4">

    <a asp-action="ManagePatients"
       class="btn btn-secondary">

        Back to Patients

    </a>

</div>