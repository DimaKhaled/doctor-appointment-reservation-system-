@using Dams.Web.ViewModels.Admin
@model EditSpecializationViewModel

@{
    ViewData["Title"] = "Edit Specialization";
}

<div class="auth-panel mx-auto">

    <div class="page-header">

        <h1 class="h3 mb-1">
            Edit Specialization
        </h1>

    </div>

    <div class="form-shell">

        <form asp-action="EditSpecialization"
              method="post">

            <input asp-for="SpecializationId" type="hidden" />

            <div asp-validation-summary="ModelOnly"
                 class="text-danger mb-3">
            </div>

            <div class="mb-4">

                <label asp-for="Name"
                       class="form-label">
                </label>

                <input asp-for="Name"
                       class="form-control" />

                <span asp-validation-for="Name"
                      class="text-danger"></span>

            </div>

            <button class="btn btn-primary">
                Save Changes
            </button>

            <a asp-action="ManageSpecializations"
               class="btn btn-secondary">
                Cancel
            </a>

        </form>

    </div>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}