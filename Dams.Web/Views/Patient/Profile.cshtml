@model Dams.Web.ViewModels.Patient.PatientProfileViewModel

@{
    ViewData["Title"] = "My Profile";
}

<div class="page-header">
    <h1 class="h3 mb-1">My Profile</h1>
    <p class="text-muted mb-0">View and update your personal information and profile picture.</p>
</div>

<div class="form-shell">
    <div class="d-flex align-items-center gap-3 mb-4">
        @if (!string.IsNullOrWhiteSpace(Model.ProfilePicturePath))
        {
            <img src="@Model.ProfilePicturePath" alt="Profile picture" class="profile-picture" />
        }
        else
        {
            <div class="profile-picture-placeholder">@Model.FullName.Substring(0, 1)</div>
        }
        <div>
            <div class="fw-semibold">@Model.FullName</div>
            <div class="text-muted small">@Model.Email</div>
        </div>
    </div>

    <form asp-action="Profile" method="post" enctype="multipart/form-data" novalidate>
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row g-3 mb-3">
            <div class="col-md-6">
                <label class="form-label">Email</label>
                <input type="text" class="form-control" value="@Model.Email" disabled readonly />
            </div>
            <div class="col-md-6">
                <label class="form-label">Gender</label>
                <input type="text" class="form-control" value="@Model.Gender" disabled readonly />
            </div>
            <div class="col-md-6">
                <label class="form-label">Date of Birth</label>
                <input type="text" class="form-control" value="@Model.DateOfBirth.ToString("yyyy-MM-dd")" disabled readonly />
            </div>
        </div>

        <div class="row g-3 mb-3">
            <div class="col-md-6">
                <label asp-for="FullName" class="form-label"></label>
                <input asp-for="FullName" class="form-control" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="PhoneNumber" class="form-label"></label>
                <input asp-for="PhoneNumber" class="form-control" />
                <span asp-validation-for="PhoneNumber" class="text-danger"></span>
            </div>
        </div>

        <div class="row g-3 mb-3">
            <div class="col-md-4">
                <label asp-for="BloodType" class="form-label"></label>
                <input asp-for="BloodType" class="form-control" placeholder="e.g. O+" />
                <span asp-validation-for="BloodType" class="text-danger"></span>
            </div>
        </div>

        <div class="mb-3">
            <label asp-for="Allergies" class="form-label"></label>
            <textarea asp-for="Allergies" class="form-control" rows="2" placeholder="e.g. Penicillin, peanuts"></textarea>
            <span asp-validation-for="Allergies" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="ChronicDiseases" class="form-label"></label>
            <textarea asp-for="ChronicDiseases" class="form-control" rows="2" placeholder="e.g. Diabetes, hypertension"></textarea>
            <span asp-validation-for="ChronicDiseases" class="text-danger"></span>
        </div>

        <div class="mb-4">
            <label asp-for="ProfilePicture" class="form-label"></label>
            <input asp-for="ProfilePicture" type="file" accept=".jpg,.jpeg,.png" class="form-control" />
            <span asp-validation-for="ProfilePicture" class="text-danger"></span>
            <div class="form-text">JPG or PNG. Max 5 MB.</div>
        </div>

        <button type="submit" class="btn btn-primary">Save Changes</button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
