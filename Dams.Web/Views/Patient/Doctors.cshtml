@model Dams.Web.ViewModels.Patient.DoctorSearchViewModel

@{
    ViewData["Title"] = "Find a Doctor";
}

<div class="page-header">
    <h1 class="h3 mb-1">Find a Doctor</h1>
    <p class="text-muted mb-0">Browse, search, and filter doctors to find the right fit.</p>
</div>

<form asp-action="Doctors" method="get" class="form-shell mb-4">
    <div class="row g-3 align-items-end">
        <div class="col-md-3">
            <label asp-for="Keyword" class="form-label">Search</label>
            <input asp-for="Keyword" class="form-control" placeholder="Doctor name or specialization" />
        </div>
        <div class="col-md-2">
            <label asp-for="SpecializationId" class="form-label">Specialization</label>
            <select asp-for="SpecializationId" class="form-select">
                <option value="">All</option>
                @foreach (var spec in Model.SpecializationOptions)
                {
                    <option value="@spec.SpecializationId">@spec.Name</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label asp-for="City" class="form-label">City</label>
            <select asp-for="City" class="form-select">
                <option value="">All</option>
                @foreach (var city in Model.CityOptions)
                {
                    <option value="@city">@city</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label asp-for="Gender" class="form-label">Gender</label>
            <select asp-for="Gender" class="form-select">
                <option value="">All</option>
                <option value="Male">Male</option>
                <option value="Female">Female</option>
            </select>
        </div>
        <div class="col-md-2">
            <label asp-for="SortBy" class="form-label">Sort By</label>
            <select asp-for="SortBy" class="form-select">
                <option value="@Dams.Web.ViewModels.Patient.DoctorSearchViewModel.SortOptions.NameAsc">Name (A-Z)</option>
                <option value="@Dams.Web.ViewModels.Patient.DoctorSearchViewModel.SortOptions.NameDesc">Name (Z-A)</option>
                <option value="@Dams.Web.ViewModels.Patient.DoctorSearchViewModel.SortOptions.ExperienceDesc">Experience (Highest First)</option>
                <option value="@Dams.Web.ViewModels.Patient.DoctorSearchViewModel.SortOptions.ExperienceAsc">Experience (Lowest First)</option>
            </select>
        </div>
        <div class="col-md-1">
            <button type="submit" class="btn btn-primary w-100">Go</button>
        </div>
    </div>
</form>

@if (Model.Doctors.Count == 0)
{
    <partial name="_EmptyState" model="@("No doctors found matching your search criteria.")" />
}
else
{
    <div class="row g-3">
        @foreach (var doctor in Model.Doctors)
        {
            <div class="col-md-4">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            @if (!string.IsNullOrWhiteSpace(doctor.ProfilePicturePath))
                            {
                                <img src="@doctor.ProfilePicturePath" alt="@doctor.FullName" class="profile-picture" />
                            }
                            else
                            {
                                <div class="profile-picture-placeholder">@doctor.FullName.Substring(0, 1)</div>
                            }
                            <div>
                                <div class="fw-semibold">@doctor.FullName</div>
                                <div class="text-muted small">@doctor.SpecializationName</div>
                            </div>
                        </div>
                        <ul class="list-unstyled small text-muted mb-3">
                            <li>@doctor.Gender &middot; @doctor.ExperienceYears yrs experience</li>
                            <li>@doctor.ClinicName, @doctor.City</li>
                            <li>
                                @if (doctor.ReviewCount > 0)
                                {
                                    var reviewLabel = doctor.ReviewCount == 1 ? "review" : "reviews";
                                    <text>@doctor.AverageRating.ToString("0.0") ★ (@doctor.ReviewCount @reviewLabel)</text>
                                }
                                else
                                {
                                    <span>No reviews yet</span>
                                }
                            </li>
                        </ul>
                        <a asp-action="DoctorProfile" asp-route-id="@doctor.DoctorId" class="btn btn-outline-primary btn-sm">View Profile</a>
                    </div>
                </div>
            </div>
        }
    </div>
}
