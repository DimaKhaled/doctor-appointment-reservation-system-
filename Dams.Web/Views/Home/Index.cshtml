@using Dams.Web.Models
@using Dams.Web.ViewModels.Patient

@{
    ViewData["Title"] = "Home";
    var specializations = ViewBag.Specializations as List<Specialization> ?? new();
    var featuredDoctors = ViewBag.FeaturedDoctors as List<DoctorListItemViewModel> ?? new();
}
@* Hero Section *@
<section class="hero-section rounded-4 p-5 mb-5 text-white"
         style="background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 60%, #084298 100%);">

    <div class="row align-items-center">

        <div class="col-lg-7">

            <p class="text-uppercase fw-semibold small mb-2 opacity-75">
                Doctor Appointment Management System
            </p>

            <h1 class="display-5 fw-bold mb-3">
                Book Your Doctor Appointment in Minutes
            </h1>

            <p class="lead mb-4 opacity-90">
                Find the right specialist, check availability, and book your appointment — all in one place.
            </p>

            <div class="d-flex flex-wrap gap-3">
                <a class="btn btn-white btn-lg fw-semibold text-primary shadow-sm"
                       asp-controller="Account"
                       asp-action="Register">
                    Create Account
                </a>

                <a class="btn btn-outline-light btn-lg"
                       asp-controller="Account"
                       asp-action="Login">
                    Sign In
                </a>
            </div>

        </div>

        <div class="col-lg-5 d-none d-lg-flex justify-content-center align-items-center">

            <div class="text-center">
                <span style="font-size:8rem;">🩺</span>

                <h4 class="mt-3 fw-semibold">
                    Find Trusted Doctors
                </h4>

                <p class="opacity-75 mb-0">
                    Fast, secure and easy appointment booking.
                </p>
            </div>

        </div>

    </div>

</section>
@* Specializations Section *@
@if (specializations.Count > 0)
{
    <section class="mb-5">

        <div class="d-flex align-items-center gap-2 mb-1">
            <span class="fs-3">🏥</span>
            <h2 class="h4 fw-bold mb-0">Browse by Specialization</h2>
        </div>

           <p class="text-muted m-4">
             Find the right doctor for your needs.
          </p>

        @{
            var icons = new[] { "🫀", "🧠", "👶", "🦴", "👁️", "🦷", "🫁", "💊", "🩺", "👂" };
            int i = 0;
        }

        <div class="row g-3">

            @foreach (var spec in specializations)
            {
                var icon = icons[i % icons.Length];
                i++;

                <div class="col-6 col-md-4 col-lg-3 col-xl-2">

                    <a asp-controller="Account"
                           asp-action="Login"
                           class="text-decoration-none">

                        <div class="card border-0 shadow-sm h-100 text-center p-3 specialization-card">

                            <div class="fs-2 mb-2">
                                @icon
                            </div>

                            <div class="fw-semibold small text-dark">
                                @spec.Name
                            </div>

                        </div>

                    </a>

                </div>
            }

        </div>

    </section>
}
<style>
    .specialization-card {
        transition: transform .15s ease, box-shadow .15s ease;
        cursor: pointer;
        border-radius: 16px;
    }

        .specialization-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 24px rgba(0,0,0,.12) !important;
        }
</style>
@* Featured Doctors Section *@
@if (featuredDoctors.Count > 0)
{
    <section class="mb-5">

        <div class="d-flex align-items-center gap-2 mb-1">
            <span class="fs-3">👨‍⚕️</span>
            <h2 class="h4 fw-bold mb-0">Meet Our Doctors</h2>
        </div>

        <p class="text-muted m-4">
            Experienced specialists ready to help.
        </p>

        <div class="row g-4">

            @foreach (var doctor in featuredDoctors)
            {
                <div class="col-md-4">

                    <div class="card border-0 shadow-sm h-100 doctor-card"
                         style="transition: transform .15s, box-shadow .15s;">

                        <div class="card-body p-4">

                            <div class="d-flex align-items-center gap-3 mb-3">

                                @if (!string.IsNullOrWhiteSpace(doctor.ProfilePicturePath))
                                {
                                    <img src="@doctor.ProfilePicturePath"
                                         alt="@doctor.FullName"
                                         class="rounded-circle object-fit-cover"
                                         style="width:56px;height:56px;" />
                                }
                                else
                                {
                                    <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center flex-shrink-0 fw-bold fs-5"
                                         style="width:56px;height:56px;">
                                        @doctor.FullName.Substring(0, 1)
                                    </div>
                                }

                                <div>
                                    <div class="fw-bold">@doctor.FullName</div>
                                    <span class="badge text-bg-light border text-primary small">
                                        @doctor.SpecializationName
                                    </span>
                                </div>

                            </div>

                            <div class="text-muted small mb-1">
                                📍 @doctor.ClinicName, @doctor.City
                            </div>

                            <div class="text-muted small mb-3">
                                🎓 @doctor.ExperienceYears yrs experience
                            </div>

                            @if (doctor.ReviewCount > 0)
                            {
                                var reviewLabel = doctor.ReviewCount == 1 ? "review" : "reviews";

                                <div class="text-warning small mb-3">
                                    @for (int s = 1; s <= 5; s++)
                                    {
                                        <span>@(s <= (int)doctor.AverageRating ? "★" : "☆")</span>
                                    }

                                    <span class="text-muted ms-1">
                                        (@doctor.ReviewCount @reviewLabel)
                                    </span>
                                </div>
                            }

                            <a asp-controller="Account"
                                   asp-action="Login"
                                   class="btn btn-primary btn-sm w-100">
                                Book Appointment
                            </a>

                        </div>

                    </div>

                </div>
            }

        </div>

    </section>

}

<style>
    .specialization-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(0,0,0,.12) !important;
    }

    .btn-white {
        background: #fff;
        border-color: #fff;
    }

        .btn-white:hover {
            background: #f0f0f0;
        }

    .opacity-90 {
        opacity: .9;
    }
</style> 



@* CTA Section *@
<section class="rounded-4 p-5 mb-4 text-center"
         style="background: linear-gradient(135deg, #e8f4fd 0%, #dbeafe 100%);">

    <span class="fs-1 d-block mb-3">🩺</span>

    <h2 class="h4 fw-bold mb-2">Ready to get started?</h2>

    <p class="text-muted mb-4">
        Join now and book your first appointment today.
    </p>

    <a class="btn btn-primary btn-lg px-5 shadow-sm"
           asp-controller="Account"
           asp-action="Register">
        Create a Free Account
    </a>

</section>

